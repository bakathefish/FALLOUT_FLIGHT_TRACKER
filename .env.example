# --- database (Supabase Postgres) ---
# pooled connection, transaction mode, port 6543. used at runtime by the app.
# get this from Supabase dashboard > project settings > database > connection pooling.
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres"
# direct connection, port 5432. used ONLY for migrations (drizzle-kit).
DIRECT_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# --- write auth ---
# shared passcode required to add a flight. share this in the cohort chat.
WRITE_PASSCODE="change-me"
# your override to edit or delete any row.
ADMIN_PASSCODE="change-me-too"

# --- map tiles ---
# MapTiler key for the dark vector tiles. omit if you use the protomaps fallback.
NEXT_PUBLIC_MAPTILER_KEY=""

# --- event ---
NEXT_PUBLIC_EVENT_NAME="Fallout 2026"
# used for the countdown. ISO 8601 with offset.
NEXT_PUBLIC_EVENT_START_ISO="2026-07-01T00:00:00+08:00"

# --- feed (optional) ---
# JSON override of the ADS-B feed bubbles: [[lat, lon, radiusNm], ...]
# default is the Pearl River Delta bubble. max radius 250 nm per center.
# ADSB_CENTERS="[[22.47, 113.86, 250]]"

# set to 1 in tests/e2e to serve recorded fixtures instead of the real feed.
# MOCK_ADSB="0"
